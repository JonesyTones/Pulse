# PULSE Environment Variables Template
# Copy to server/.env and client/.env and fill in real values before running

# ---- server/.env ----
GROQ_API_KEY=
YOUTUBE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=pulse-app/1.0
PORT=3001
ALLOWED_ORIGIN=https://your-vercel-app.vercel.app
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# ---- client/.env ----
VITE_API_BASE_URL=http://localhost:3001
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
